{
   "action": {
      "default_popup": "popup.html",
      "default_title": "LiveTiming Settings"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "css": [ "styles.css" ],
      "js": [ "content.js" ],
      "matches": [ "https://livetiming.azurewebsites.net/*" ],
      "all_frames": true,
      "run_at": "document_end"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "Customizable themes and lap alerts for LiveTiming websites",
   "host_permissions": [ "https://livetiming.azurewebsites.net/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "manifest_version": 3,
   "name": "LiveTiming Dark Theme & Lap Alerts",
   "permissions": [ "storage", "activeTab", "scripting", "notifications" ],
   "version": "1.0.0",
   "web_accessible_resources": [ {
      "matches": [ "https://livetiming.azurewebsites.net/*" ],
      "resources": [ "tailwind.min.css" ]
   } ]
}
